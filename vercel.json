{
  "version": 2,
  "builds": [
    { "src": "api/send-email.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/send-email", "dest": "/api/send-email.js" },
    { "src": "/(.*\\.html)", "dest": "/$1" },
    { "src": "/", "dest": "/regjistrohu.html" }
  ]
}
